<script>
  async function handleGenerate() {
    const btn = document.getElementById('btn-generate');
    const originalText = btn.innerHTML;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> กำลังสร้าง...';
    btn.disabled = true;

    // Get Inputs
    const brandInfo = document.getElementById('input-brand-info').value;
    const businessType = document.getElementById('input-business-type').value;
    const tone = document.getElementById('input-tone').value;
    const platform = document.getElementById('input-platform').value;
    const format = document.getElementById('input-format').value;
    const productInfo = document.getElementById('input-product-info').value;

    if (!brandInfo) {
      showToast('กรุณากรอกข้อมูลแบรนด์หรือเลือกจาก Sheets');
      btn.innerHTML = originalText;
      btn.disabled = false;
      return;
    }

    // Construct Prompt (คล้าย TSX)
    const promptText = `
      สร้างโซเชียลมีเดียคอนเทนต์จำนวน 3 รายการ สำหรับช่องทาง: ${platform}
      ข้อมูลแบรนด์: ${brandInfo}
      ประเภทธุรกิจ: ${businessType}
      โทนเสียง: ${tone}
      สินค้า/โปรโมชั่น: ${productInfo || 'ไม่ระบุ'}
      รูปแบบสื่อ: ${format}
      
      คำแนะนำ Visual: 
      - ถ้าเป็น Album ให้แจกแจงทีละภาพ
      - ถ้าเป็น Video ให้แจกแจงทีละซีน
      
      ตอบกลับเป็น JSON ตาม Schema เท่านั้น
    `;

    const systemPrompt = `คุณคือ AI Social Media Expert สร้างคอนเทนต์ให้ดึงดูดใจ เหมาะกับแพลตฟอร์ม ${platform}`;

    // Call Backend
    google.script.run
      .withSuccessHandler(function(res) {
        btn.innerHTML = originalText;
        btn.disabled = false;

        if (res.success) {
          renderResults(res.data.contents);
          showToast('สร้างคอนเทนต์สำเร็จ!');
        } else {
          showToast('Error: ' + res.error);
        }
      })
      .withFailureHandler(function(err) {
        btn.innerHTML = originalText;
        btn.disabled = false;
        showToast('เกิดข้อผิดพลาดในการเชื่อมต่อ');
      })
      .callGeminiUniversal(
        promptText, 
        systemPrompt, 
        [], // No files for now
        CONTENT_SCHEMA, 
        GEMINI_API_KEY,
        [{ "google_search": {} }] // Enable Search Grounding
      );
  }

  function renderResults(contents) {
    const container = document.getElementById('output-container');
    container.innerHTML = '';

    contents.forEach((item, index) => {
      const card = document.createElement('div');
      card.className = 'bg-slate-800 border border-slate-700 rounded-xl p-5 shadow-lg hover:border-indigo-500 transition';
      
      // Format Hashtags
      const tags = item.hashtags.map(t => t.startsWith('#') ? t : '#' + t).join(' ');

      card.innerHTML = `
        <div class="flex justify-between items-center mb-3 border-b border-slate-700 pb-2">
          <h3 class="font-bold text-indigo-400">Post #${index + 1}</h3>
          <button onclick="copyText(this, \`${item.caption.replace(/`/g, '\\`')}\n\n${tags}\`)" class="text-xs text-slate-400 hover:text-white flex items-center gap-1">
            <i class="fa-regular fa-copy"></i> คัดลอก
          </button>
        </div>
        
        <div class="space-y-3">
          <div>
            <span class="text-xs font-bold text-slate-500 uppercase">Headline</span>
            <p class="text-lg font-bold text-white mt-1">${item.headline}</p>
          </div>
          
          <div>
            <span class="text-xs font-bold text-slate-500 uppercase">Caption</span>
            <div class="bg-slate-900 p-3 rounded-lg text-sm text-slate-300 whitespace-pre-wrap mt-1 border border-slate-700">
              ${item.caption}
            </div>
          </div>

          <div>
            <span class="text-xs font-bold text-slate-500 uppercase">Hashtags</span>
            <p class="text-sm text-blue-400 mt-1">${tags}</p>
          </div>

          <div class="bg-amber-900/20 border border-amber-900/50 p-3 rounded-lg">
            <span class="text-xs font-bold text-amber-500 uppercase flex items-center gap-1">
              <i class="fa-solid fa-lightbulb"></i> Visual Idea
            </span>
            <p class="text-xs text-amber-200/80 mt-1 italic whitespace-pre-wrap">${item.visual_suggestion}</p>
          </div>
        </div>
      `;
      container.appendChild(card);
    });
  }

  function copyText(btn, text) {
    navigator.clipboard.writeText(text).then(() => {
      const original = btn.innerHTML;
      btn.innerHTML = '<i class="fa-solid fa-check text-emerald-400"></i> แล้ว!';
      setTimeout(() => btn.innerHTML = original, 2000);
    });
  }
</script>
